DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# SQLite database path for analysis history records.
AI_OPSLOG_DB_PATH=data/ai_opslog.db

# Optional token for Alertmanager webhook.
# If empty, token check is disabled.
# If set, requests must include X-Alertmanager-Token.
# Do not commit a real token.
ALERTMANAGER_WEBHOOK_TOKEN=

# Optional Prometheus base URL for read-only metric snapshot.
# Example: http://127.0.0.1:9090
PROMETHEUS_BASE_URL=
PROMETHEUS_TIMEOUT_SECONDS=3

# Optional read-only Docker / Kubernetes runtime snapshot.
# The app only runs fixed read-only commands such as docker ps and kubectl get.
AI_OPSLOG_ENABLE_DOCKER_SNAPSHOT=true
AI_OPSLOG_ENABLE_KUBERNETES_SNAPSHOT=true
RUNTIME_SNAPSHOT_TIMEOUT_SECONDS=3
RUNTIME_SNAPSHOT_MAX_ITEMS=8
DOCKER_BIN=docker
KUBECTL_BIN=kubectl
